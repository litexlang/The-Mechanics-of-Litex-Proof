know:
    forall a R b R:
        a>0
        b>0
        =>:
            a*b>0
    forall a R b R c R:
        a>0
        b>c
        =>:
            a*b>a*c
    forall a,b R:
        a>0
        b>0
        =>:
            b<a+b
    forall a,b R:
        a*b=0
        =>:
            a=0 or b=0
    forall a,b R:
        a*b!=0
        =>:
            a!=0 and b!=0
    