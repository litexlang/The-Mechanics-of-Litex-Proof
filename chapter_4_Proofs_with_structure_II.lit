            $mod_eq_trans(a, b, c, n)
    forall a, b, c,d, n Z:
        $mod_eq(a, b, n)
        $mod_eq(c, d, n)
        =>:
            $mod_eq(a * c, b * d, n)
            $mod_eq(a + c, b + d, n)

know:
    forall a Z:
        =>:
            $mod_eq(a, 0, 2)
        <=>:
            $even(a)
    forall a Z:
        =>:
            $mod_eq(a, 1, 2)
        <=>:
            $odd(a)
