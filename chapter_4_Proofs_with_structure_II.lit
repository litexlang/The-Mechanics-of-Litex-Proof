# ---------------------------------------------------------------------------
# 4.3 存在唯一（∃!）
# ---------------------------------------------------------------------------

# 4.3.1
# 先证见证（此处 2）满足式子，再设 y 为任一解，由 3y+1=7 推出 y=2。
"""
Show that there exists a unique real number a such that 3a+1=7.
"""
# 存在唯一（∃!）：先 witness 存在性，再证任意解等于该见证（litex_statement.lit 无单独 ∃! 关键字，拆成 exist + 全称蕴含）。
claim:
    prove:
        exist a R st {3 * a + 1 = 7}
    witness exist a R st {3 * a + 1 = 7} from 2:
        3 * 2 + 1 = 7
forall y R:
    3 * y + 1 = 7
    =>:
        y = (3 * y + 1 - 1) / 3 = (7 - 1) / 3 = 2

# 4.3.2
# 唯一有理数 x：使对所有 a∈[1,3] 有 (a-x)^2<=1 者为 x=2（书本：用端点 1 与 3 夹住）。
"""
Show that there exists a unique rational number x such that for every rational a between 1 and 3, (a-x)^2 <= 1.
"""

know:
    forall a,b R:
        a<=b
        -b<=a
        =>:
            a^2<=b^2
prop sq_le_1(x Q):
    forall a Q:
        a<=3
        a>=1
        =>:
            (a-x)^2 <= 1
claim:
    prove:
        exist_unique x Q st {$sq_le_1(x)}
    witness exist x Q st {$sq_le_1(x)} from 2:
        forall a Q:
            a<=3
            a>=1
            =>:
                a-2<=3-2=1
                a-2>=1-2=-1
                -1<=a-2<=1
                (a-2)^2<=1^2=1
        $sq_le_1(2)
    forall x,y Q:
        $sq_le_1(x)
        $sq_le_1(y)
        =>:
            (1-x)^2<=1
            (1-y)^2<=1
            -1<=1-x
            -1<=1-y
            x=-(1-x)+1<=1+1=2
            y=-(1-y)+1<=1+1=2
            (3-x)^2<=1
            (3-y)^2<=1
            3-x<=1
            3-y<=1
            x=3-(3-x)<=3-1=2
            y=3-(3-y)>=3-1=2
            2<=x<=2
            2<=y<=2
            x=2
            y=2
            x=y
            

    

# 4.3.3
# 若 ∃! a, a^2=x，则 (-a)^2=x ⇒ -a=a ⇒ a=0 ⇒ x=0。
"""
Let x be a rational number, and suppose there exists a unique rational a such that a^2=x. Show that x=0.
"""
# 设 a 为满足 a^2=x 的唯一有理数，则 (-a)^2=x，由唯一性 -a=a，故 a=0，x=0（形式化需 have by exist 引入见证；见书本 Lean 的 obtain ⟨a, ha1, ha2⟩）。
# （目标命题依赖「唯一性」假设，不单写成 forall x: x=0。）
#不知道怎么写
"""
claim:
    prove:
        forall x Q:
            exist a Q st {a^2 = x}
            =>:
                x = 0
"""

# 4.3.4
# 除法算法：∃! r, 0<=r<b 且 a≡r (mod b)。特例 r=4 为 14 mod 5。（长证明见书本；Lean：Int.existsUnique_modEq_lt。）
"""
Show that there exists a unique integer r such that 0 <= r < 5 and 14 ≡ r (mod 5).
"""
let min_pos_remain fn (a Z, b Z) Z
know:
    forall a, b Z:
        b>0
        =>:
            exist r Z st {0 <= r and r < b and $mod_eq(a, r, b)}
   
    forall a,b Z:
        b>0
        =>:
            $mod_eq(a, min_pos_remain(a, b), b)
            min_pos_remain(a, b) >= 0
            min_pos_remain(a, b) < b
    forall a,b,r Z:
        b>0
        r<b
        r>=0
        $mod_eq(a, r, b)
        =>:
            r=min_pos_remain(a,b)
claim:
    prove:
        exist r Z st {0 <= r and r < 5 and $mod_eq(14, r, 5)}
    witness exist r Z st {0 <= r and r < 5 and $mod_eq(14, r, 5)} from 4:
        0 <= 4
        4 < 5
        witness exist c Z st {14-4 = 5 * c } from 2:
            14 = 5 * 2 + 4
        $mod_eq(14, 4, 5)
forall r Z:
    0 <= r and r < 5 and $mod_eq(14, r, 5)
    =>:
        0<=r
        r<5
        r=min_pos_remain(14,5)


# ---------------------------------------------------------------------------
# 4.4 矛盾的假设
# ---------------------------------------------------------------------------

# 4.4.1
# 若 0<xy 且 0<=x，则 0<y：若 y<=0 则 xy<=0 与 0<xy 矛盾。（Lean：contradiction。）
"""
Lemma: Let x and y be real numbers, and suppose 0 < x*y and 0 <= x. Show that 0 < y.
"""
# 分情形：y≤0 时 0=x·0≥x·y 与 0<x·y 矛盾；故 y>0（Lean：contradiction）。
claim:
    prove:
        forall x, y R:
            0 < x * y
            0 <= x
            =>:
                0 < y
    by contra:
        prove:
            0 < y
        y<=0
        x*y<=x*0=0
        impossible x*y<=0
        

# 4.4.2
# t<3 且 t-1=6 ⇒ t=7<3，假命题 ⇒ 爆炸原理可推出任意结论（含 t=13）。（Lean：numbers at H。）
"""
Let t be an integer with t < 3 and t - 1 = 6. Show that t = 13.
"""
#不知道如何用litex表述这个事情（爆炸原理）
"""
forall t Z:
    t < 3
    t - 1 = 6
    =>:
        t = 13
        
"""
# 4.4.3
# n mod 3 为 0 或 2 则结论已成立；若 n≡1 (mod 3) 则 n^2+n+1≡3≡0 (mod 3)，与 ≡1 矛盾。（同余须规范到 0..n-1 再判「显然假」。）
"""
Show that if n^2+n+1 ≡ 1 (mod 3) then n ≡ 0 or n ≡ 2 (mod 3).
"""

know:
    forall n Z:
        $mod_eq(n, 0, 3) or $mod_eq(n, 2, 3) or $mod_eq(n, 1, 3)
#无法在prop里面做化简计算

"""
claim:
    prove:
        forall n Z:
            $mod_eq(n^2+n+1, 1, 3)
            =>:
                $mod_eq(n, 0, 3) or $mod_eq(n, 2, 3)
    
    $mod_eq(n, 0, 3) or $mod_eq(n, 2, 3) or $mod_eq(n, 1, 3)
    by cases:
        prove:
            $mod_eq(n, 0, 3) or $mod_eq(n, 2, 3)
        case $mod_eq(n, 0, 3):
            $mod_eq(n, 0, 3)
        case $mod_eq(n, 2, 3):
            $mod_eq(n, 2, 3)
        case $mod_eq(n, 1, 3):
            $mod_eq(n*n, 1*1, 3)
            $mod_eq(n*n+n, 1*1+1, 3)
            witness exist c Z st {1-1= 3 * c} from 0:
                1-1= 3 * 0
            $mod_eq(1, 1, 3)
            1*1+1+1=3
            $mod_eq(n*n+n+1, 1*1+1+1, 3)
            $mod_eq(n*n+n+1, 3, 3)
            n*n=n^2
            $mod_eq(n^2+n+1, 0, 3)
            impossible $mod_eq(n^2+n+1, 0, 3)
"""

# 4.4.4
# 素数判定引理：若 2<=p 且所有满足 1<m<p 的 m 都不整除 p，则 p 素数（prime_test）。证 5：枚举 m=2,3,4。
"""
Lemma: Let p >= 2. If for all m with 1 < m < p, m does not divide p, then p is prime.
Show that 5 is prime.
"""
know:
    forall p N:
        p >= 2
        forall m N:
            1 < m < p
            =>:
                not $dvdN(m, p)
        =>:
            $Prime(p)

#不知道怎么写

"""
claim:
    prove:
        $Prime(5)
    by for:
        prove:
            forall i 2...4:
                5 % i != 0
                not $dvdN(i, 5)
        
"""    
    

# 4.4.5
# 勾股数 a^2+b^2=c^2 且 a,b,c 为正 ⇒ a>=3（最小本原解 3,4,5）。书本对 a<=2 分情形导出矛盾（较长）。
"""
Let a, b, c be positive natural numbers with a^2 + b^2 = c^2. Show that 3 <= a.
"""

# ---------------------------------------------------------------------------
# 4.5 反证法
# ---------------------------------------------------------------------------

# 4.5.1
# 否定全称：¬∀x, P(x) —— 举反例 x=0.5（使 x^2 < x）。
"""
Show that it is not true that for all real numbers x, x^2 >= x.
"""
witness exist x R st {x^2 < x} from 0.5:
    0.5^2 < 0.5

# 4.5.2
# 13 不是 3 的倍数：若 13=3k，则 k<=4 或 k>=5 均矛盾。
"""
Show that 13 is not a multiple of 3.
"""
"""
claim:
    prove:
        not $dvdN(3, 13)
    by contra:
        prove:
            not $dvdN(3, 13)
        $dvdN(3, 13)
        exist k N st {13 = 3 * k}
        k <= 4 or k >= 5
        by cases:
            prove:
                not $dvdN(3, 13)
            case k <= 4:
                13 = 3 * k<=3*4=12
                impossible 13 <=12
            case k >= 5:
                13 = 3 * k>=3*5=15
                impossible 13 >=15
"""
# 4.5.3
# x+y=0 时不能同时 x>0 且 y>0（否则 0=x+y>0）。
"""
Let x and y be real numbers and suppose x + y = 0. Show it is not possible for both x and y to be positive.
"""
claim:
    prove:
        forall x, y R:
            x + y = 0
            =>:
                x<=0 or y<=0
    x>0 or x<=0
    by cases:
        prove:
            x<=0 or y<=0
        case x<=0:
            x<=0
        case x>0:
            y=x+y-x=0-x<0
            y<=0


# 4.5.4
# 无自然数 n 满足 n^2=2（与 2.3.2 对照）。
"""
Show that there does not exist a natural number n such that n^2 = 2.
"""
claim:
    prove:
        forall n N:
            =>:
                n^2 != 2
    n<=1 or n>=2
    by cases:
        prove:
            n^2!=2
        case n<=1:
            n^2<=1^2=1<2
            n^2!=2
        case n>=2:
            n>=2
            n^2>=2^2=4>2
            n^2!=2



# 4.5.5
# 偶 ⇔ 非奇；奇 ⇔ 非偶（整数；用 mod 2 或分类讨论）。
"""
Show that an integer n is even if and only if it is not odd; odd if and only if not even.
"""

# 4.5.6
# n^2 ≢ 2 (mod 3)：对 n mod 3 枚举 0,1,2。
"""
Let n be an integer. Show that n^2 not≡ 2 (mod 3).
"""
#得完善剩余类这个事情
"""
claim:
    prove:
        forall n Z:
            not $mod_eq(n^2, 2, 3)
    $mod_eq(n, 0, 3) or $mod_eq(n, 1, 3) or $mod_eq(n, 2, 3)
    by cases:
        prove:
            not $mod_eq(n^2, 2, 3)
        case $mod_eq(n, 0, 3):
            $mod_eq(n^2, 0^2, 3)
            $mod_eq(n^2, 0, 3)
            not $mod_eq(n^2, 2, 3)
        case $mod_eq(n, 1, 3):
            $mod_eq(n^2, 1^2, 3)
            $mod_eq(n^2, 1, 3)
            not $mod_eq(n^2, 2, 3)
        case $mod_eq(n, 2, 3):
            $mod_eq(n^2, 2^2, 3)
            $mod_eq(n^2, 4, 3)
            $mod_eq(n^2, 1, 3)
            not $mod_eq(n^2, 2, 3)
"""

# 4.5.7
# p=k*l 且 k≠1、k≠p ⇒ p 非素数（书本定理）。
"""
Let p, k, l be natural numbers with k != 1, k != p, and p = k*l. Then p is not prime.
"""
know:
    forall a,b R:
        a*b!=0
        =>:
            a!=0
            b!=0
"""
claim:
    prove:
        forall p, k, l N:
            k != 1
            k != p
            p = k * l
            =>:
                not $Prime(p)
    p=0 or p!=0
    by cases:
        prove:
            not $Prime(p)
        case p=0:
            not $Prime(0)
        case p!=0:
            p!=0
            p=k*l
            k!=1
            k!=p
    by contra:
        prove:
            not $Prime(p)
        $Prime(p)
        k != 1 and k != p
        p = k * l !=0
        k!=0
        l!=0
        k<p
        1<k
        witness exist l N st {p = k * l} from l:
            p = k * l
        $dvdN(k, p)
        impossible $dvdN(k, p)
"""

