# Chapter 4 — 结构化证明 II

# 第二章学过 ∨、∧、∃，以及假设/目标中各联结词的 natural deduction 用法。
# 本章补全其余逻辑符号：∀、→、¬；以及可由它们定义的 ↔ 与 ∃!。


prop odd(a Z):
    exist k Z st {a = 2 * k + 1}
prop even(a Z):
    exist k Z st {a = 2 * k}
prop dvdN(a N, b N):
    a>=1
    exist c N st {b = a * c}
prop dvdZ(a Z, b Z):
    a!=0
    exist c Z st {b = a * c}
prop mod_eq(a Z, b Z, n Z):
    exist k Z st {a - b = n * k}

know:
    forall a,b N:
        =>:
            $dvdN(a, b)
        <=>:
            a != 0
            b % a = 0

let odd_num fn(a Z:$odd(a)) Z
let even_num fn(a Z:$even(a)) Z
know:
    forall a Z:
        $odd(a)
        =>:
            a = 2 * odd_num(a) + 1
    forall a Z:
        $even(a)
        =>:
            a = 2 * even_num(a)
let dvd_num_z fn(a Z, b Z:$dvdZ(a, b)) Z
let dvd_num_n fn(a N, b N:$dvdN(a, b)) N
know:
    forall a, b Z:
        $dvdZ(a, b)
        =>:
            b = a * dvd_num_z(a, b)
    forall a, b N:
        $dvdN(a, b)
        =>:
            b = a * dvd_num_n(a, b)


know:
    forall a, b N:
        $dvdN(a, b)
        b > 0
        =>:
            a <= b
    forall a, b N:
        $dvdN(a, b)
        b > 0
        =>:
            a >= 1

# ---------------------------------------------------------------------------
# 4.1 「对所有」与蕴含（∀ 与 →）
# ---------------------------------------------------------------------------

# 4.1.1
# 把公式或谓词说成「对所有 x 成立」，称为对 x 的全称量化，符号写作 ∀。
# 使用带 ∀ 的假设时，常把其中的 x 代成某个具体值（特例化）；纸面下例取 x=1。
# （Lean：对假设用 apply 特例化。）
"""
Let a be a real number and suppose that for all real numbers x, a <= x^2 - 2x. Show that a <= -1.
"""

forall a R:
    forall x R:
        a <= x^2 - 2 * x
    =>:
        a <= 1^2 - 2 * 1 = -1



# 4.1.2
# n 整除每个自然数 ⇒ n 整除 1；又 1>0，由因子大小界（第三章例 3.2.7、3.2.8）得 n<=1 且 1<=n，故 n=1。
"""
Let n be a natural number which is a factor of every natural number m. Show that n = 1.
"""

know:   
    forall n,m N:
        $dvdN(n, m)
        =>:
            n<=m

forall n N:
    forall m N:
        $dvdN(n, m)
    =>:
        $dvdN(n, 1)
        0 < 1
        n <= 1
        1 <= n

# 4.1.3
# 考虑 (a+b)/2：它要么 >= a，要么 <= b；两种情形分别推出 b>=a 或 a<=b。
# （Lean：对析取假设分情形；此处 Litex 用 by cases。）
"""
Let a and b be real numbers and suppose that every real number x is either at least a or at most b. Show that a <= b.
"""

claim:
    prove:
        forall a, b R:
            forall x R:
                x >= a or x <= b
            =>:
                a <= b
    (a+b)/2 >= a or (a+b)/2 <= b
    by cases:
        prove:
            a <= b
        case (a+b)/2 >= a:
            b = 2 * ((a + b) / 2) - a >= 2 * a - a = a
            a <= b
        case (a+b)/2 <= b:
            a = 2 * ((a + b) / 2) - b <= 2 * b - b = b
            a <= b

# 4.1.4
# 假设里「a 大于等于每个平方不超过 2 的实数」= ∀y∈R, y^2<=2 → y<=a（前件 y^2<=2 可特例化）。
# 由 a^2<=2 得 a<=b；由 b^2<=2 得 b<=a；故 a=b。
# 脚注：即 a 在集合 {y | y^2<=2} 中是极大的。
"""
Let a be real number whose square is at most 2, and which is greater than or equal to any real number whose square is at most 2.
Let b be another real number with the same two properties. Prove that a = b.
"""
know:
    forall a, b R:
        a<=b
        b<=a
        a=b
forall a, b R:
    a^2 <= 2
    b^2 <= 2
    forall y R:
        y^2 <= 2
        =>:
            y <= a
    forall y R:
        y^2 <= 2
        =>:
            y <= b
    =>:
        a^2 <= 2
        a <= b
        b^2 <= 2
        b <= a
        a = b

# 4.1.5
# 目标含 ∀x：先「设 x 为任意实数」再证不等式。（Lean：intro x 后 calc。）
"""
Show that there exists a real number b such that for every real number x, b <= x^2 - 2x.
"""
#exists 里面是否要加入forall
prop b_le_x_sq_minus_2_x(b R):
    forall x R:
        b <= x^2 - 2 * x

claim:
    prove:
        exist b R st {$b_le_x_sq_minus_2_x(b)}
    witness exist b R st {$b_le_x_sq_minus_2_x(b)} from -1:
        forall x R:
            -1 <= -1 + (x - 1)^2 = x^2 - 2 * x
            -1 <= x^2 - 2 * x

# 4.1.6
# 目标：∃c, ∀x,y, (x^2+y^2<=4 → x+y>=c)。先引入 x,y 与假设 x^2+y^2<=4，再估 (x+y)^2。
# 引理 abs_le_of_sq_le_sq'：见第二章例 2.4.2（书本）。
"""
Show that there exists a real number c such that for all real numbers x and y, if x^2 + y^2 <= 4 then x + y >= c.
"""
prop x_sq_plus_y_sq_le_4(c R):
    forall x, y R:
        x^2 + y^2 <= 4
        =>:
            x + y >= c
know:
    forall x, y R:
        x^2 <= y^2
        y >= 0
        =>:
            -y <= x
            x <= y
claim:
    prove:
        exist c R st {$x_sq_plus_y_sq_le_4(c)}
    witness exist c R st {$x_sq_plus_y_sq_le_4(c)} from -3:
        forall x, y R:
            x^2 + y^2 <= 4
            =>:
                (x + y)^2 <= (x + y)^2 + (x - y)^2 = 2 * (x^2 + y^2) <= 2 * 4 = 8 <= 9 = 3^2
                x + y >= -3

# 4.1.7
# 定义：性质对「所有充分大的整数 n」成立，指存在整数 N，使得对所有 n>=N 该性质成立（有理数、实数同理）。
# （Lean：记号 forall_sufficiently_large；先用 use 给出阈值再 intro n hn。）
"""
Show that for all sufficiently large integers n, n^3 >= 4 n^2 + 7.
"""
prop n_ge_n_sq_plus_7(M Z):
    forall n Z:
        n >= M
        =>:
            n^3 >= 4 * n^2 + 7
# 对 n >= 5：n^3 = n*n^2 >= 5 n^2 = 4 n^2 + n^2 >= 4 n^2 + 25 > 4 n^2 + 7
"""
claim:
    prove:
        exist M Z st {$n_ge_n_sq_plus_7(M)}
    witness exist M Z st {$n_ge_n_sq_plus_7(M)} from 5:
        forall n Z:
            n >= 5
            =>:
                n^3=n*(n^2) >= 5 *(n^2)=4 * (n^2) + (n^2) >= 4 * (n^2) + 5^2 = 4 * (n^2) + 7 + 18
                n^3 >= 4 * (n^2) + 7 + 18>4 * (n^2) + 7
                n^3 >= 4 * (n^2) + 7
"""
# 4.1.8
# 定义：自然数 p 为素数，当且仅当 p>=2 且 p 的正因子只有 1 与 p。
# 证 2 为素数：2<=2；设 m|2，则由大小界 m<=2 且 1<=m，枚举 m∈{1,2}。（Lean：interval_cases。）

prop Prime(p N):
    2 <= p
    forall m N:
        $dvdN(m, p)
        =>:
            m = 1 or m = p

"""
Show that 2 is prime.
"""

claim:
    prove:
        $Prime(2)
    2 <= 2
    forall m N:
        $dvdN(m, 2)
        =>:
            0 < 2
            m <= 2
            1 <= m
            m = 1 or m = 2

# 4.1.9
# 证「非素数」：给出一个非平凡分解 p=k*l 且 k≠1、k≠p。（完整论证见 4.5.7；Lean 引理 not_prime。）
"""
Show that 6 is not prime.
"""
# 因子 2 满足 2|6 且 2≠1、2≠6，与素数定义矛盾（亦见 4.5.7 引理 not_prime）。
