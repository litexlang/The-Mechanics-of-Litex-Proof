# 4.2 当且仅当（↔）
# ---------------------------------------------------------------------------

# 4.2.1
# 「当且仅当」须证两个方向。（纸面常用 ⇒ 与 ⇐ 标注；正式书写可用「首先」「反之」。）
# （Lean：↔ 目标用 constructor 拆成两个蕴含。）
"""
Let a be a rational number. Show that 3a+1 <= 7 if and only if a <= 2.
"""
# 正向：3a+1<=7 ⇒ a<=2；反向：a<=2 ⇒ 3a+1<=7。
forall a Q:
    3 * a + 1 <= 7
    =>:
        a = ((3 * a + 1) - 1) / 3 <= (7 - 1) / 3 = 2
forall a Q:
    a <= 2
    =>:
        3 * a + 1 <= 3 * 2 + 1 = 7

# 4.2.2
# 8|5n ⇒ 8|n：由 5n=8a 得 n = -3(5n)+16n = 8(-3a+2n)。反之 8|n ⇒ 8|5n 显然。
"""
Let n be an integer. Show that 5n is a multiple of 8 if and only if n is.
"""
#n =-3*(5*n)+16*n= -3*(8*dvd_num_z(8, 5 * n))+16*n= 8*(-3*dvd_num_z(8, 5 * n)+2*n)这一串不能verify
"""
# ⇒：8∣5n ⇒ 8∣n；⇐：8∣n ⇒ 8∣5n。
claim:
    prove:
        forall n Z:
            $dvdZ(8, 5 * n)
            =>:
                $dvdZ(8, n)
    witness exist c Z st {n = 8 * c} from (-3*dvd_num_z(8, 5 * n)+2*n):
        n =-3*(5*n)+16*n= -3*(8*dvd_num_z(8, 5 * n))+16*n= 8*(-3*dvd_num_z(8, 5 * n)+2*n)
claim:
    prove:
        forall n Z:
            $dvdZ(8, n)
            =>:
                $dvdZ(8, 5 * n)
    witness exist c Z st {5 * n = 8 * c} from 5*dvd_num_z(8, n):
        5 * n = 5 * n= 5*(8 * dvd_num_z(8, n) )= 8 * (5 * dvd_num_z(8, n))
"""

# 4.2.3 / 4.2.4
# 奇数 ⇔ n ≡ 1 (mod 2)；偶数 ⇔ n ≡ 0 (mod 2)。（书本定理 odd_iff_modEq、even_iff_modEq；反向分支 Lean 留作 sorry。）
"""
Show that an integer n is odd, if and only if it is congruent to 1 modulo 2.
Show that an integer n is even, if and only if it is congruent to 0 modulo 2.
"""
claim:
    prove:
        forall n Z:
            $odd(n)
            =>:
                $mod_eq(n, 1, 2)
    witness exist c Z st {n-1 = 2 * c} from odd_num(n):
        n-1=  2 * odd_num(n) +1-1=2*odd_num(n)

claim:
    prove:
        forall n Z:
            $mod_eq(n, 1, 2)
            =>:
                $odd(n)
    $dvdZ(2,n-1)
    witness exist c Z st {n = 2 * c + 1} from dvd_num_z(2,n-1):
        n=n-1+1 = 2 * dvd_num_z(2,n-1) + 1

claim:
    prove:
        forall n Z:
            $even(n)
            =>:
                $mod_eq(n, 0, 2)
    witness exist c Z st {n-0 = 2 * c} from even_num(n):
        n-0=n= 2 * even_num(n)
claim:
    prove:
        forall n Z:
            $mod_eq(n, 0, 2)
            =>:
                $even(n)
    $dvdZ(2,n-0)
    witness exist c Z st {n = 2 * c} from dvd_num_z(2,n-0):
        n=n-0= 2 * dvd_num_z(2,n-0)    


# 4.2.5
# 解方程型 ↔：左边因式分解 (x+3)(x-2)=0 ⇒ x=-3 或 x=2；反向代入验证。
"""
Let x be a real number. Show that x^2 + x - 6 = 0 if and only if x = -3 or x = 2.
"""
forall x R:
    x^2 + x - 6 = 0
    =>:
        x^2 + x - 6 = (x + 3) * (x - 2) = 0
        x + 3 = 0 or x - 2 = 0
        x =x+3-3=0-3=-3 or x =x-2+2=0+2=2 

forall x R:
    x = -3 or x = 2
    =>:
        x+3=-3+3=0
        x-2=2-2=0
        x^2 + x - 6 = (x + 3) * (x - 2) = 0 * 0 = 0
        x^2 + x - 6 = 0

# 4.2.6
# 配方 (2a-5)^2 = 4(a^2-5a+5)+5，由左边<=-1 得 |2a-5|<=1 ⇒ 2<=a<=3，整数 a∈{2,3}。
"""
Let a be an integer. Show that a^2 - 5a + 5 <= -1 if and only if a is 2 or 3.
"""
know:
    forall a,b R:
        a^2<=b^2
        b>=0
        =>:
            -b<=a
            a<=b
forall a Z:
    a^2 - 5 * a + 5 <= -1
    =>:
        (2*a-5)^2 = 4*(a^2-5*a+5)+5 <= 4*(-1)+5 = -4+5 = 1
        (2*a-5)^2 <= 1
        -1 <= 2*a-5 
        2*a-5 <= 1
        a=(2*a-5+5)/2<=1+5/2=3
        a=(2*a-5+5)/2>=2+5/2=2
        2 <= a <= 3
        a = 2 or a = 3
claim:
    prove:
        forall a Z:
            a = 2 or a = 3
            =>:
                a^2 - 5 * a + 5 <= -1
    by cases:
        prove:
                a^2 - 5 * a + 5 <= -1
        case a = 2:
            a^2 - 5 * a + 5 = 2^2 - 5 * 2 + 5 = 4 - 10 + 5 = -1
            a^2 - 5 * a + 5 <= -1
        case a = 3:
            a^2 - 5 * a + 5 = 3^2 - 5 * 3 + 5 = 9 - 15 + 5 = -1
            a^2 - 5 * a + 5 <= -1
        
# 4.2.7

"""
Let n be an integer and suppose n^2 - 10n + 24 = 0. Show that n is even.
"""
claim:
    prove:
        forall n Z:
            n^2 - 10 * n + 24 = 0
            =>:
                $even(n)
    0=n^2 - 10 * n + 24 = (n - 4) * (n - 6) = 0
    n - 4 = 0 or n - 6 = 0
    n =n- 4 + 4=0+4=4 or n =n- 6 + 6 = 0+6 = 6
    n=4 or n=6
    by cases:
        prove:
            $even(n)
        case n = 4:
            witness exist c Z st {n = 2 * c} from 2:
                n =4= 2 * 2 
        case n = 6:
            witness exist c Z st {n = 2 * c} from 3:
                n =6= 2 * 3 

