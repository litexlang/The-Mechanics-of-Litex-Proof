# ---------------------------------------------------------------------------
# 3.3 Modular arithmetic: theory（a ≡ b (mod n) ⇔ n | (a-b) ⇔ exist k, a-b = n*k）
# ---------------------------------------------------------------------------

prop mod_eq(a Z, b Z, n Z):
    exist k Z st {a - b = n * k}
let mod_num_z fn(a Z, b Z, n Z:$mod_eq(a, b, n)) Z
know:
    forall a, b, n Z:
        $mod_eq(a, b, n)
        =>:
            a - b = n * mod_num_z(a, b, n)
# 3.3.1
"""
Show that 11 ≡ 3 (mod 4).
"""
claim:
    prove:
        $mod_eq(11, 3, 4)
    witness exist k Z st {11 - 3 = 4 * k} from 2:
        11 - 3 = 4 * 2

# 3.3.2
"""
Show that -5 ≡ 1 (mod 3).
"""
claim:
    prove:
        $mod_eq(-5, 1, 3)
    witness exist k Z st {(-5) - 1 = 3 * k} from -2:
        (-5) - 1 = 3 * (-2)

# 3.3.3（加法：同余式相加）
"""
Lemma: If a ≡ b (mod n) and c ≡ d (mod n), then a+c ≡ b+d (mod n).
"""
claim:
    prove:
        forall a, b, c, d, n Z:
            $mod_eq(a, b, n)
            $mod_eq(c, d, n)
            =>:
                $mod_eq(a + c, b + d, n)
    a-b=n*mod_num_z(a, b, n)
    c-d=n*mod_num_z(c, d, n)
    witness exist k Z st {(a + c) - (b + d) = n * k} from mod_num_z(a, b, n) + mod_num_z(c, d, n):
        (a + c) - (b + d) = (a - b) + (c - d) = n * (mod_num_z(a, b, n)) + n * (mod_num_z(c, d, n)) = n * (mod_num_z(a, b, n) + mod_num_z(c, d, n))

# 3.3.4（减法：Exercise）
"""
Lemma: If a ≡ b (mod n) and c ≡ d (mod n), then a-c ≡ b-d (mod n).
"""
claim:
    prove:
        forall a, b, c, d, n Z:
            $mod_eq(a, b, n)
            $mod_eq(c, d, n)
            =>:
                $mod_eq(a - c, b - d, n)
    a-b=n*mod_num_z(a, b, n)
    c-d=n*mod_num_z(c, d, n)
    witness exist k Z st {(a - c) - (b - d) = n * k} from mod_num_z(a, b, n) - mod_num_z(c, d, n):
        (a - c) - (b - d) = (a - b) - (c - d) = n * mod_num_z(a, b, n) - n * mod_num_z(c, d, n) = n * (mod_num_z(a, b, n) - mod_num_z(c, d, n))

# 3.3.5（取负：Exercise）
"""
Lemma: If a ≡ b (mod n), then -a ≡ -b (mod n).
"""
claim:
    prove:
        forall a, b, n Z:
            $mod_eq(a, b, n)
            =>:
                $mod_eq(-a, -b, n)
    a-b=n*mod_num_z(a, b, n)
    witness exist k Z st {(-a) - (-b) = n * k} from -mod_num_z(a, b, n):
        (-a) - (-b) = -(a - b) = -(n * mod_num_z(a, b, n)) = n * (-mod_num_z(a, b, n))

# 3.3.6（乘法）
"""
Lemma: If a ≡ b (mod n) and c ≡ d (mod n), then a*c ≡ b*d (mod n).
"""
claim:
    prove:
        forall a, b, c, d, n Z:
            $mod_eq(a, b, n)
            $mod_eq(c, d, n)
            =>:
                $mod_eq(a * c, b * d, n)
    a-b=n*mod_num_z(a, b, n)
    c-d=n*mod_num_z(c, d, n)
    witness exist k Z st {a * c - b * d = n * k} from mod_num_z(a, b, n) * c + b * mod_num_z(c, d, n):
        a * c - b * d = (a - b) * c + b * (c - d) = n * mod_num_z(a, b, n) * c + b * (n * mod_num_z(c, d, n)) = n * (mod_num_z(a, b, n) * c + b * mod_num_z(c, d, n))

# 3.3.7（无“除法”规则：反例）
"""
It is impossible to prove that if a ≡ b (mod n) and c ≡ d (mod n), then (a/c) ≡ (b/d) (mod n).
"""
# a=10,b=18,c=2,d=6,n=4：10≡18，2≡6，但 (10/2)-(18/6)=2 不≡0 (mod 4)。

# 3.3.8（平方）
"""
Lemma: If a ≡ b (mod n), then a^2 ≡ b^2 (mod n).
"""
claim:
    prove:
        forall a, b, n Z:
            $mod_eq(a, b, n)
            =>:
                $mod_eq(a^2, b^2, n)
    a-b=n*mod_num_z(a, b, n)
    witness exist k Z st {a^2 - b^2 = n * k} from mod_num_z(a, b, n) * (a + b):
        a^2 - b^2 = (a - b) * (a + b) = n * mod_num_z(a, b, n) * (a + b) = n * (mod_num_z(a, b, n) * (a + b))

# 3.3.9（立方：Exercise）
"""
Lemma: If a ≡ b (mod n), then a^3 ≡ b^3 (mod n).
"""
claim:
    prove:
        forall a, b, n Z:
            $mod_eq(a, b, n)
            =>:
                $mod_eq(a^3, b^3, n)
    a-b=n*mod_num_z(a, b, n)
    witness exist k Z st {a^3 - b^3 = n * k} from mod_num_z(a, b, n) * (a^2 + a * b + b^2):
        a^3 - b^3 = (a - b) * (a^2 + a * b + b^2) = n * mod_num_z(a, b, n) * (a^2 + a * b + b^2) = n * (mod_num_z(a, b, n) * (a^2 + a * b + b^2))

# 3.3.10（自反）
"""
Lemma: a ≡ a (mod n).
"""
claim:
    prove:
        forall a, n Z:
            =>:
                $mod_eq(a, a, n)
    witness exist k Z st {a - a = n * k} from 0:
        a - a = n * 0

# 3.3.11
"""
Let a and b be integers, and suppose that a ≡ 2 (mod 4). Show that
a*b^2 + a^2*b + 3*a ≡ 2*b^2 + 2^2*b + 3*2 (mod 4).
"""
claim:
    prove:
        forall a, b Z:
            $mod_eq(a, 2, 4)
            =>:
                $mod_eq(a * b^2 + a^2 * b + 3 * a, 2 * b^2 + 2^2 * b + 3 * 2, 4)
    a-2=4*mod_num_z(a, 2, 4)
    witness exist k Z st {a * b^2 + a^2 * b + 3 * a - (2 * b^2 + 2^2 * b + 3 * 2) = 4 * k} from mod_num_z(a, 2, 4) * (b^2 + a * b + 2 * b + 3):
        a * b^2 + a^2 * b + 3 * a - (2 * b^2 + 2^2 * b + 3 * 2) = (a - 2) * (b^2 + a * b + 2 * b + 3) = 4 * mod_num_z(a, 2, 4) * (b^2 + a * b + 2 * b + 3) = 4 * (mod_num_z(a, 2, 4) * (b^2 + a * b + 2 * b + 3))

# ---------------------------------------------------------------------------
# 3.4 Modular arithmetic: calculations
# ---------------------------------------------------------------------------

# 3.4.1
# 与 3.3.11 同题；书本说明熟练后可用“一眼”验证，Lean 中可用 rel 等。

# 3.4.2
"""
Let a and b be integers, with a ≡ 4 (mod 5) and b ≡ 3 (mod 5). Show that a*b + b^3 + 3 ≡ 2 (mod 5).
a*b + b^3 + 3 ≡ 4*3 + 3^3 + 3 = 42 = 2 + 5*8 ≡ 2 (mod 5)。）
"""
prop mod_eq_trans(a,b,c,n Z):
    $mod_eq(a,c,n)

know:
    forall a, b, c, n Z:
        $mod_eq(a, b, n)
        $mod_eq(b, c, n)
        =>:
            $mod_eq_trans(a, b, c, n)
    forall a, b, c,d, n Z:
        $mod_eq(a, b, n)
        $mod_eq(c, d, n)
        =>:
            $mod_eq(a * c, b * d, n)
            $mod_eq(a + c, b + d, n)
# 代表元（同余类下结论不变）：先算数值，再对照 3.3 乘法/加法引理
claim:
    prove:
        forall a, b Z:
            $mod_eq(a, 4, 5)
            $mod_eq(b, 3, 5)
            =>:
                $mod_eq(a * b + b^3 + 3, 2, 5)
    $mod_eq(a*b, 4*3, 5)
    $mod_eq(b^3, 3^3, 5)
    $mod_eq(a*b+b^3, 4*3+3^3, 5)
    $mod_eq(3, 3, 5)
    $mod_eq(a * b + b^3 + 3, 4*3 + 3^3 + 3, 5)
    witness exist k Z st {4*3 + 3^3 + 3 - 2 = 5 * k} from 8:
        4*3 + 3^3 + 3 - 2 = 5 * 8
    $mod_eq(4*3 + 3^3 + 3, 2, 5)
    $mod_eq_trans(a * b + b^3 + 3, 4*3 + 3^3 + 3, 2, 5)
    $mod_eq(a * b + b^3 + 3, 2, 5)

# 3.4.3
"""
Show that there exists an integer a such that 6a ≡ 4 (mod 11).
"""

claim:
    prove:
        exist a Z st {$mod_eq(6 * a, 4, 11)}
    witness exist a Z st {$mod_eq(6 * a, 4, 11)} from 8:
        witness exist c Z st {6 * 8 -4=11 * c} from 4:
            6 * 8 - 4 = 11 * 4 
        $mod_eq(6 * 8, 4, 11)

