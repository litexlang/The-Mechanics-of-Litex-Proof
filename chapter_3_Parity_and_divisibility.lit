# Chapter 3 — Parity and divisibility 
# ---------------------------------------------------------------------------
# 3.1 Definitions; parity
# ---------------------------------------------------------------------------

prop odd(a Z):
    exist k Z st {a = 2 * k + 1}
prop even(a Z):
    exist k Z st {a = 2 * k}

"""
let odd_num fn(a Z:$odd(a)) Z
let even_num fn(a Z:$even(a)) Z
know:
    forall a Z:
        $odd(a)
        =>:
            a = 2 * odd_num(a) + 1
    forall a Z:
        $even(a)
        =>:
            a = 2 * even_num(a)
"""

# SOLVED: 不建议写let fn，更好的是用 have fn 直接得到函数。

claim:
    prove:
        forall a Z:
            $odd(a)
            =>:
                (a - 1) / 2 $in Z
    have by exist k Z st {a = 2 * k + 1}: k
    k = ((2 * k + 1) - 1) / 2 = (a - 1) / 2

claim:
    prove:
        forall a Z:
            $even(a)
            =>:
                a / 2 $in Z
    have by exist k Z st {a = 2 * k}: k
    k = (2 * k) / 2 = a / 2

have fn odd_num(a Z:$odd(a)) Z = (a - 1) / 2
forall a Z:
    $odd(a)
    =>:
        (a - 1) / 2 = odd_num(a)
        a = 2 * ((a - 1) / 2) + 1 = 2 * odd_num(a) + 1
have fn even_num(a Z:$even(a)) Z = a / 2
forall a Z:
    $even(a)
    =>:
        a / 2 = even_num(a)
        a = 2 * (a / 2) = 2 * even_num(a)

# 3.1.1
"""
Show that 7 is odd.
"""
claim:
    prove:
        $odd(7)
    witness exist k Z st {7 = 2 * k + 1} from 3:
        7 = 2 * 3 + 1

# 3.1.2
"""
Show that -3 is odd.
"""
claim:
    prove:
        $odd(-3)
    witness exist k Z st {-3 = 2 * k + 1} from -2:
        -3 = 2 * (-2) + 1

# 3.1.3
"""
Prove that if n is an odd integer, then 3n + 2 is odd.
"""
claim:
    prove:
        forall n Z:
            $odd(n)
            =>:
                $odd(3 * n + 2)
    n=2*odd_num(n)+1
    witness exist l Z st {3 * n + 2 = 2 * l + 1} from 3 * odd_num(n) + 2:
        3 * n + 2 = 3 * (2 * odd_num(n) + 1) + 2 = 2 * (3 * odd_num(n) + 2) + 1

# 3.1.4
"""
Let n be an integer. Prove that if n is odd, then 7n - 4 is odd.
"""
claim:
    prove:
        forall n Z:
            $odd(n)
            =>:
                $odd(7 * n - 4)
    n=2*odd_num(n)+1
    witness exist l Z st {7 * n - 4 = 2 * l + 1} from 7 * odd_num(n) + 1:
        7 * n - 4 = 7 * (2 * odd_num(n) + 1) - 4 = 2 * (7 * odd_num(n) + 1) + 1

# 3.1.5
"""
Prove that if the integers x and y are odd, then x + y + 1 is odd.
"""
claim:
    prove:
        forall x, y Z:
            $odd(x)
            $odd(y)
            =>:
                $odd(x + y + 1)
    x=2*odd_num(x)+1
    y=2*odd_num(y)+1
    witness exist l Z st {x + y + 1 = 2 * l + 1} from odd_num(x) + odd_num(y) + 1:
        x + y + 1 = (2 * odd_num(x) + 1) + (2 * odd_num(y) + 1) + 1 = 2 * (odd_num(x) + odd_num(y) + 1) + 1

# 3.1.6
"""
Prove that if the integers x and y are odd, then x*y + 2*y is odd.
"""
claim:
    prove:
        forall x, y Z:
            $odd(x)
            $odd(y)
            =>:
                $odd(x * y + 2 * y)
    x=2*odd_num(x)+1
    y=2*odd_num(y)+1
    witness exist l Z st {x * y + 2 * y = 2 * l + 1} from 2 * odd_num(x) * odd_num(y) + 3 * odd_num(y) + odd_num(x) + 1:
        x * y + 2 * y = (2 * odd_num(x) + 1) * (2 * odd_num(y) + 1) + 2 * (2 * odd_num(y) + 1) = 2 * (2 * odd_num(x) * odd_num(y) + 3 * odd_num(y) + odd_num(x) + 1) + 1

# 3.1.7
"""
Let m be an integer. Prove that if m is odd, then 3m - 5 is even.
"""
claim:
    prove:
        forall m Z:
            $odd(m)
            =>:
                $even(3 * m - 5)
    m=2*odd_num(m)+1
    witness exist l Z st {3 * m - 5 = 2 * l} from 3 * odd_num(m) - 1:
        3 * m - 5 = 3 * (2 * odd_num(m) + 1) - 5 = 2 * (3 * odd_num(m) - 1)

# 3.1.8
"""
Let n be an even integer. Prove that n^2 + 2n - 5 is odd.
"""
claim:
    prove:
        forall n Z:
            $even(n)
            =>:
                $odd(n^2 + 2 * n - 5)
    n=2*even_num(n)
    witness exist l Z st {n^2 + 2 * n - 5 = 2 * l + 1} from 2 * even_num(n)^2 + 2 * even_num(n) - 3:
        n^2 + 2 * n - 5 = (2 * even_num(n))^2 + 2 * (2 * even_num(n)) - 5 = 2 * (2 * even_num(n)^2 + 2 * even_num(n) - 3) + 1

# 3.1.9
"""
Let n be an integer. Prove that n^2 + n + 4 is even.
（分 n 偶 / n 奇；引理：整数要么偶要么奇。）
"""
know:
    forall n Z:
        =>:
            $even(n) or $odd(n)
claim:
    prove:
        forall n Z:
            =>:
                $even(n^2 + n + 4)
    by cases:
        prove:
            $even(n^2 + n + 4)
        case $even(n):
            n=2*even_num(n)
            witness exist l Z st {n^2 + n + 4 = 2 * l} from 2 * even_num(n)^2 +  even_num(n) + 2:
                n^2 + n + 4 = (2 * even_num(n))^2 +  (2 * even_num(n)) + 4 = 2 * (2 * even_num(n)^2 +  even_num(n) + 2)
        case $odd(n):
            n=2*odd_num(n)+1
            witness exist l Z st {n^2 + n + 4 = 2 * l} from 2 * odd_num(n)^2 + 3 * odd_num(n) + 3:
                n^2 + n + 4 = (2 * odd_num(n) + 1)^2 + (2 * odd_num(n) + 1) + 4 = 2 * (2 * odd_num(n)^2 + 3 * odd_num(n) + 3)

# ---------------------------------------------------------------------------
# 3.2 Divisibility
# ---------------------------------------------------------------------------

# TODO: 请完成：参考 23-57行的代码把这里的let改成have fn

prop dvdZ(a Z, b Z):
    exist c Z st {b = a * c}
prop dvdN(a N, b N):
    exist c N st {b = a * c}

let dvd_num_z fn(a Z, b Z:$dvdZ(a, b)) Z
let dvd_num_n fn(a N, b N:$dvdN(a, b)) N

know:
    forall a, b Z:
        $dvdZ(a, b)
        =>:
            b = a * dvd_num_z(a, b)
    forall a, b N:
        $dvdN(a, b)
        =>:
            b = a * dvd_num_n(a, b)



# 3.2.1
"""
Show that the natural number 88 is divisible by 11.
"""
claim:
    prove:
        $dvdN(11, 88)
    witness exist c N st {88 = 11 * c} from 8:
        88 = 11 * 8

# 3.2.2
"""
Show that the integer 6 is divisible by -2.
"""
claim:
    prove:
        $dvdZ(-2, 6)
    witness exist c Z st {6 = (-2) * c} from -3:
        6 = (-2) * (-3)

# 3.2.3
"""
Let a and b be integers and suppose that a | b. Show that a | b^2 + 2b.
"""
claim:
    prove:
        forall a, b Z:
            $dvdZ(a, b)
            =>:
                $dvdZ(a, b^2 + 2 * b)
    b=a*dvd_num_z(a, b)
    witness exist c Z st {b^2 + 2 * b = a * c} from a * dvd_num_z(a, b)^2 + 2 * dvd_num_z(a, b):
        b^2 + 2 * b  = (a*dvd_num_z(a, b))^2 + 2 * (a*dvd_num_z(a, b)) = a^2 * dvd_num_z(a, b)^2 + 2 * a * dvd_num_z(a, b) = a * (a * dvd_num_z(a, b)^2 + 2 * dvd_num_z(a, b))
